{
  "manifest_version": 3,
  "name": "Browsing Assistant",
  "version": "1.1",
  "description": "Chat with an AI that controls your browser — built with Vercel AI SDK + Webfuse MCP",
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "host_permissions": ["<all_urls>"],
  "env": [
    { "key": "API_URL", "value": "", "description": "Next.js server URL (e.g. https://your-app.vercel.app)" }
  ]
}
