{
  "manifest_version": 3,
  "name": "Hacker News Copilot 🍊",
  "version": "1.2",
  "description": "Your AI sidekick for the orange site — reads, summarizes, clicks, and comments",
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "host_permissions": ["<all_urls>"],
  "env": [
    { "key": "API_URL", "value": "", "description": "Next.js server URL (e.g. https://your-app.vercel.app)" }
  ]
}
